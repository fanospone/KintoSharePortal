@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewBag.Title = "My Book";
}
<link href="~/Content/dataTables.bootstrap.min.css" rel="stylesheet" />
<link href="~/Content/jquery.dataTables.min.css" rel="stylesheet" />
<link href="~/Content/responsive.bootstrap.min.css" rel="stylesheet" />
<link href="~/Content/sweetalert/sweetalert.css" rel="stylesheet" />
<script src="~/Scripts/GlobalConfig.js"></script>
<h2>@ViewBag.Title.</h2>
<h3>@ViewBag.Message</h3>
<meta charset="utf-8" />
@model KintoSharePortal.Domain.Models.trxKintoSharePortalAsset
<link href="~/Content/jquery-ui.multidatespicker.css" rel="stylesheet" />


<div class="row clearfix" id="divmybooklist">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    MY BOOK
                </h2>
            </div>
            <div class="body">
                <form class="row g-3">
                    @using (Html.BeginForm("Index", "Home", FormMethod.Get))
                    {
                        <div id="content">
                            <div style="height: auto;width: 100%;margin: 0px auto">
                                <table class="table table-striped table-bordered dt-responsive nowrap" style="width:100%" id="tblBookHeader" cellspacing="0">
                                    <thead>
                                        <tr>
                                            <th class="text-center">ID</th>
                                            <th class="text-center">BOOK NO.</th>
                                            <th class="text-center">VACEHILE</th>
                                            <th class="text-center">PLAT NO.</th>
                                            <th class="text-center">DEPARTMENT</th>
                                            <th class="text-center">PIC</th>
                                            <th class="text-center">BOOK DATE</th>
                                            <th class="text-center">BOOK FREQ.</th>
                                            <th class="text-center">BOOK STATUS</th>
                                            <th class="text-center">REQUESTER</th>
                                            <th class="text-center">PURPOSE</th>
                                            <th class="text-center">REQUEST DATE</th>
                                            <th class="text-center">CHECK-IN</th>
                                            <th class="text-center">CHECK-OUT</th>
                                            <th class="text-center">CANCEL BOOK</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                        <div class="row clearfix">
                            <div class="col-lg-12">
                                <button type="button" class="btn bg-teal btn-block btn-lg waves-effect" id="btbook">Book Vechile</button>
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row clearfix" id="divdetail">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    BOOKING DETAIL
                </h2>
            </div>
            <div class="body">
                <form class="row g-3">
                    <div class="row clearfix">
                        <div class="col-lg-6">
                            <p>
                                <b> Car Type</b>
                            </p>
                            @*<input type="text" class="form-control" id="cartype" name="cartype">*@
                            <select class="form-control show-tick" id="cartype" name="cartype" onchange="Control.GetPlatNo(this)">
                            </select>
                        </div>
                        <div class="col-lg-6">
                            <p>
                                <b>Department</b>
                            </p>
                            <select class="form-control show-tick" name="department" id="department" onchange="Control.GetPIC(this)">
                                @*<option value="">Choose Department</option>*@
                            </select>
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-lg-6">
                            <p>
                                <b> License Plat No.</b>
                            </p>
                            <input type="text" class="form-control" id="licenseplat" name="licenseplat" disabled="disabled">
                        </div>
                        <div class="col-lg-6">
                            <p>
                                <b>PIC</b>
                            </p>
                            <select class="form-control bootstrap-select show-tick" name="ddpic" id="ddpic">
                                @*<option value="">Choose Department</option>*@
                            </select>
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-lg-6">
                            <p>
                                <b> Book Type</b>
                            </p>
                            <input type="text" class="form-control" id="booktype" name="booktype" value="DAILY" disabled>
                        </div>
                        <div class="col-lg-6">
                            <p>
                                <b> Purpose</b>
                            </p>
                            @*<input type="text" class="form-control" id="purpose" name="purpose">*@
                            <select class="form-control bootstrap-select show-tick" name="purpose" id="purpose">
                                <option value="">Please choose</option>
                                <option value="Personal">Personal</option>
                                <option value="Office">Office</option>
                            </select>
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-md-3">
                            <h2 class="card-inside-title">Start Book Date</h2>
                            <div class="pickup">
                                <input id="datebookstart" class="form-control datepicker-inline" placeholder="Please choose a date..." type="text" onchange="checkDate();">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <h2 class="card-inside-title">End Book Date</h2>
                            <div class="pickup">
                                <input id="datebookend" class="form-control datepicker-inline" placeholder="Please choose a date..." type="text" onchange="checkDate();">
                            </div>
                        </div>
                        @*<div class="col-lg-6">
                                <p>
                                    <b> Book Repeat</b>
                                </p>
                                <select class="form-control bootstrap-select show-tick" name="bookrepeat" id="bookrepeat">
                                    <option value="">Please choose</option>
                                    <option value="Y">Yes</option>
                                    <option value="N">No</option>
                                </select>
                            </div>*@
                        <div class="col-lg-6">
                            <p>
                                <b> Kinto Share Fee</b>
                            </p>
                            <input type="text" class="form-control" id="kintosharefee" name="kintosharefee" disabled="disabled">
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-lg-6">
                            @*<p>
                                    <b> Repeat Frequency</b>
                                </p>
                                <select class="form-control bootstrap-select show-tick" name="datefreq" id="datefreq">
                                    <option value="">Please choose</option>
                                    <option value="D">Daily</option>
                                    <option value="W">Weekly</option>
                                </select>*@
                        </div>
                        <div class="col-lg-3">
                            <p>
                                <b> FEE WEEK DAY</b>
                            </p>
                            <label id="lblweekday"></label>
                        </div>
                        <div class="col-lg-3">
                            <p>
                                <b> FEE WEEK END</b>
                            </p>
                            <label id="lblweekend"></label>
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-md-3">
                            @*<h2 class="card-inside-title">Start Book Date</h2>
                                <div class="pickup">
                                    <input id="datebookstart" class="form-control datepicker-inline" placeholder="Please choose a date..." type="text" onchange="checkDate();">
                                </div>*@
                        </div>
                        <div class="col-md-4">
                            @*<h2 class="card-inside-title">End Book Date</h2>
                                <div class="pickup">
                                    <input id="datebookend" class="form-control datepicker-inline" placeholder="Please choose a date..." type="text" onchange="checkDate();">
                                </div>*@
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn bg-red btn-block btn-lg waves-effect" id="btcancelReq">Cancel</button>
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn bg-teal btn-block btn-lg waves-effect" id="btsubmitReq">Submit</button>
                        </div>
                        @*<input type="button" value="Click" onclick="myDate()" />*@
                        @*<p id="myId"></p>*@
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!--Modal-->
<div class="modal fade" id="myModal" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" style="color: orangered;">Attention!!</h4>
            </div>
            <div class="modal-body">
                @*<p>Some text in the modal.</p>*@
                <label id="modaltext"></label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="myModalDelete" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" style="color: orangered;">Attention!!</h4>
            </div>
            <div class="modal-body">
                <label id="modaltext"></label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<!--End Modal-->

