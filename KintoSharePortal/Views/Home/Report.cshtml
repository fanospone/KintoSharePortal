@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewBag.Title = "REPORT";
}

<link href="~/Content/dataTables.bootstrap.min.css" rel="stylesheet" />
<link href="~/Content/jquery.dataTables.min.css" rel="stylesheet" />
<link href="~/Content/responsive.bootstrap.min.css" rel="stylesheet" />
<link href="~/Content/jquery-ui.multidatespicker.css" rel="stylesheet" />
<script src="~/Scripts/GlobalConfig.js"></script>
<h2>@ViewBag.Title.</h2>
<h3>@ViewBag.Message</h3>
@model KintoSharePortal.Models.KintoShare

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    REPORT
                </h2>
            </div>
            <div class="body">
                <form class="row g-3">
                    @using (Html.BeginForm("Index", "Home", FormMethod.Get))
                    {<div class="row clearfix">
                            <div class="col-lg-3">
                                <p>
                                    <b>Type</b>
                                </p>
                                <select class="form-control bootstrap-select show-tick" name="reporttype" id="reporttype" onchange="Control.ReportType(this)">
                                    <option value="asset">Asset</option>
                                    <option value="user">User</option>
                                </select>
                            </div>
                            <div class="col-lg-3">
                                <p>
                                    <b>Booking Periode From :</b>
                                </p>
                                <div class="btn-group bootstrap-select form-control show-tick dropup">
                                    <input type="date" class="form-control" name="_from" id="Startdate">
                                </div>
                            </div>
                            <div class="col-lg-3">
                                <p>
                                    <b> To :</b>
                                </p>
                                <div class="btn-group bootstrap-select form-control show-tick">
                                    <input type="date" class="form-control" name="_to" id="Enddate">
                                </div>
                            </div>
                            <div class="col-lg-3">
                                <br />
                                <button type="submit" class="btn btn-primary btn-block" asp-action="Search" asp-controller="Home">Search</button>
                            </div>
                        </div>
                        <div class="row clearfix">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <div class="col-md-3">
                                        @*<button type="button" id="btExportExcel" class="btn green">
                                            <i class="fa fa-cloud-download"></i> Export To Excel
                                        </button>*@
                                        <a href="#" class="js-export btn btn-danger btn-xs" id="btExportExcel">Export to Excel</a>                   
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="content" >
                            <div style="height: auto;width: 100%;margin: 0px auto">
                                <table class="table table-striped table-bordered dt-responsive nowrap" style="width:100%" id="tblBookHeader" cellspacing="0">
                                    <thead>
                                        <tr>
                                            <th class="text-center">ID</th>
                                            <th class="text-center">BOOK NO.</th>
                                            <th class="text-center">ASSET</th>
                                            <th class="text-center">PLAT NO.</th>
                                            <th class="text-center">DEPARTMENT</th>
                                            <th class="text-center">PIC</th>
                                            <th class="text-center">BOOK DATE</th>
                                            <th class="text-center">BOOK FREQ.</th>
                                            <th class="text-center">BOOK STATUS</th>
                                            <th class="text-center">REQUESTER</th>
                                            <th class="text-center">PURPOSE</th>
                                            <th class="text-center">REQUEST DATE</th>
                                            <th class="text-center">KINTO SHARE FEE</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                        <div id="divReportUser">
                            <div style="height: auto;width: 100%;margin: 0px auto">
                                <table class="table table-striped table-bordered dt-responsive nowrap" style="width:100%" id="tblBookUser" cellspacing="0">
                                    <thead>
                                        <tr>
                                            <th class="text-center">ID</th>
                                            <th class="text-center">BOOK NO.</th>
                                            <th class="text-center">START DATE</th>
                                            <th class="text-center">END DATE</th>
                                            <th class="text-center">REVENUE</th>
                                            <th class="text-center">KINTO SHARE FEE</th>
                                            <th class="text-center">CHARGE</th>
                                            <th class="text-center">USER</th>
                                            <th class="text-center">PIC</th>
                                            <th class="text-center">DEPARTMENT</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                        }
                </form>
            </div>
        </div>
    </div>
</div>
@section scripts
    {
    <script type="text/javascript" src="~/Content/jquery.min.js"></script>
    <script type="text/javascript" src="~/Content/jquery.dataTables.min.js"></script>
    <script src="@Url.Content("~/Scripts/KintoShare/Report.js")" type="text/javascript"></script>
    @*<script src="~/Content/jquery-ui.multidatespicker.js" type="text/javascript"></script>*@
}