<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>Kinto Share Portal</title>

    @Styles.Render("~/bundles/bsb")

    <!-- Favicon-->
    <link rel="icon" href="~/favicon.ico" type="image/x-icon">
    @*<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />*@
    <!-- Google Fonts -->
    <link href="~/Content/bsb/css/icon.css" rel="stylesheet" />
    <link href="~/Content/bsb/css/font.css" rel="stylesheet" />
    @*<link href="~/Content/jquery.dataTables.min.css" rel="stylesheet" type="text/css" />*@
    <link href="~/Content/bsb/css/style.css" rel="stylesheet" />
    <link href="~/Content/global/plugins/ladda/ladda-themeless.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/bsb/plugins/bootstrap-material-datetimepicker/css/bootstrap-material-datetimepicker.css" rel="stylesheet" />
    <link href="~/Content/bsb/plugins/bootstrap-datepicker/css/bootstrap-datepicker.css" rel="stylesheet" />
    <link href="~/Content/bsb/plugins/waitme/waitMe.css" rel="stylesheet" />
    <link href="~/Content/bsb/plugins/bootstrap-select/css/bootstrap-select.css" rel="stylesheet" />
    @*<link href="~/Content/bsb/plugins/bootstrap/css/bootstrap.css" rel="stylesheet" />*@
    <link href="~/Content/bsb/plugins/node-waves/waves.css" rel="stylesheet" />
    <link href="~/Content/bsb/plugins/animate-css/animate.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.multidatespicker.css" rel="stylesheet" type="text/css"/>
    @*<link href="~/Content/global/font-awesome.min.css" rel="stylesheet" type="text/css"/>*@
    @*<script src="~/Content/global/plugins/jquery-ui/jquery-ui.min.js"></script>*@

    @*<script type="text/javascript" src="~/Content/jquery.min.js"></script>
        <script type="text/javascript" src="~/Content/jquery-3.4.1.min.js"></script>
        <script type="text/javascript" src="~/Content/bsb/js/datatables.min.js"></script>*@
    @*<script type="text/javascript" src="~/Content/jquery.dataTables.min.js"></script>*@
</head>

<body class="theme-red">
    <!-- Page Loader -->
    <div class="page-loader-wrapper">
        <div class="loader">
            <div class="preloader">
                <div class="spinner-layer pl-red">
                    <div class="circle-clipper left">
                        <div class="circle"></div>
                    </div>
                    <div class="circle-clipper right">
                        <div class="circle"></div>
                    </div>
                </div>
            </div>
            <p>Please wait...</p>
        </div>
    </div>
    <!-- #END# Page Loader -->
    <!-- Overlay For Sidebars -->
    <div class="overlay"></div>
    <!-- #END# Overlay For Sidebars -->
    <!-- Search Bar -->
    <div class="search-bar">
        <div class="search-icon">
            <i class="material-icons">search</i>
        </div>
        <input type="text" placeholder="START TYPING...">
        <div class="close-search">
            <i class="material-icons">close</i>
        </div>
    </div>
    <!-- #END# Search Bar -->
    <!-- Top Bar -->
    <nav class="navbar">
        <div class="container-fluid">
            <div class="navbar-header">
                <a href="javascript:void(0);" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse" aria-expanded="false"></a>
                <a href="javascript:void(0);" class="bars"></a>
                <a class="navbar-brand">Kinto Share Portal</a>
            </div>
            @*<div class="collapse navbar-collapse" id="navbar-collapse">
                    <ul class="nav navbar-nav navbar-right">
                        <li class="pull-right"><a href="javascript:void(0);" class="js-right-sidebar" data-close="true"><i class="material-icons">more_vert</i></a></li>
                    </ul>
                </div>*@
        </div>
    </nav>
    <!-- #Top Bar -->
    <section>
        <!-- Left Sidebar -->
        <aside id="leftsidebar" class="sidebar">
            <!-- User Info -->
            <div class="user-info">
                <div class="image">
                    <img src="~/Content/bsb/images/taf.png" width="48" height="48" alt="User" />
                </div>
                <div class="info-container">
                    <div class="name" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">@HttpContext.Current.Session["userid"].ToString()</div>
                    <div class="name"><strong>@HttpContext.Current.User.Identity.Name</strong></div>
                    <div class="btn-group user-helper-dropdown">
                        <i class="material-icons" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true">more_vert</i>
                        <ul class="dropdown-menu pull-right">
                            <li><a id="btnLogout" href='@Url.Action("Logout","Login")'><i class="material-icons">input</i>Sign Out</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- #User Info -->
            <!-- Menu -->
            <div class="menu">
                <ul class="list">
                    @*@if (Context.Session["userRole"] == "admin")
                        {
                            <li>
                                <a href='@Url.Action("User", "Home")'>
                                    <i class="material-icons">person</i>
                                    <span>User</span>
                                </a>
                            </li>
                        }
                        @if (Context.Session["userRole"] == "admin")
                        {
                            <li>
                                <a href='@Url.Action("Signature","Home")'>
                                    <i class="material-icons">border_color</i>
                                    <span>Signature</span>
                                </a>
                            </li>
                        }*@
                    <li>
                        <a href='@Url.Action("index","Home")'>
                            <i class="material-icons">home</i>
                            <span>HOME</span>
                        </a>
                    </li>
                    @if (HttpContext.Current.Session["userRole"].ToString() == "admin")
                    {
                        <li>
                            <a href='@Url.Action("myBook", "Home")'>
                                <i class="material-icons">book</i>
                                <span>MY BOOK</span>
                            </a>
                        </li>
                    }
                    @if (HttpContext.Current.Session["userRole"].ToString() == "admin")
                    {
                        <li>
                            <a href='@Url.Action("Facilities", "Home")'>
                                <i class="material-icons">directions_car</i>
                                <span>FACILITIES</span>
                            </a>
                        </li>
                    }
                    @if (HttpContext.Current.Session["userRole"].ToString() == "divhead" || HttpContext.Current.Session["userRole"].ToString() == "admin")
                    {
                        <li>
                            <a href='@Url.Action("BookApproval", "Home")'>
                                <i class="material-icons">done_all</i>
                                <span>BOOKING APPROVAL</span>
                            </a>
                        </li>
                    }
                    @if (HttpContext.Current.Session["userRole"].ToString() == "admin")
                    {
                        <li>
                            <a href='@Url.Action("Report", "Home")'>
                                <i class="material-icons">insert_drive_file</i>
                                <span>REPORT</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
            <!-- #Menu -->
            <!-- Footer -->
            <div class="legal">
                <div class="copyright">
                    <a href="javascript:void(0);">Kinto Share Portal - Toyota Astra Financial Services</a>
                </div>
            </div>
            <!-- #Footer -->
        </aside>
        <!-- #END# Left Sidebar -->
        <!-- Right Sidebar -->
        @*<aside id="rightsidebar" class="right-sidebar">
            </aside>*@
        <!-- #END# Right Sidebar -->
    </section>

    <section class="content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </section>

    @Scripts.Render("~/bundles/js")

    @*<script src="~/Content/bsb/plugins/bootstrap/js/bootstrap.js"></script>*@
    @* <script type="text/javascript" src="~/Content/jquery.min.js"></script>*@
    <script src="~/Scripts/jquery-ui.1.10.3.js"></script>
    <script src="~/Content/bsb/plugins/bootstrap-select/js/bootstrap-select.js"></script>
    <script src="~/Content/bsb/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
    <script src="~/Content/bsb/plugins/node-waves/waves.js"></script>
    <script src="~/Content/bsb/plugins/autosize/autosize.js"></script>
    <script src="~/Content/bsb/plugins/bootstrap-material-datetimepicker/js/bootstrap-material-datetimepicker.js"></script>
    <script src="~/Content/bsb/plugins/bootstrap-datepicker/js/bootstrap-datepicker.js"></script>
    <script src="~/Content/bsb/plugins/momentjs/moment.js"></script>
    <script src="~/Content/global/plugins/ladda/spin.min.js" type="text/javascript"></script>
    <script src="~/Content/global/plugins/ladda/ladda.min.js" type="text/javascript"></script>
    <script src="~/Content/bsb/js/demo.js"></script>
    <script src="~/Content/jquery-ui.multidatespicker.js" type="text/javascript"></script>
    <script src="../../Content/bootstrap-notify/bootstrap-notify.js"></script>
    <script src="../../Content/node-waves/waves.js"></script>
    <script src="../../Content/sweetalert/sweetalert.min.js"></script>
    @*<script src="~/content/jquery-ui.multidatespicker.js"></script>*@
    @*<script src="~/Content/bsb/js/pages/forms/basic-form-elements.js"></script>*@
    <script src="~/Content/bsb/js/admin.js"></script>
    @RenderSection("scripts", false)
</body>

</html>

<script type="text/javascript">
    $('#btnLogout').click(function () {
        HttpContext.Session["userId"] == null;
    })
</script>
